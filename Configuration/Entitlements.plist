<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CRITICAL: Accessibility permission to interact with UI -->
	<key>com.apple.security.accessibility</key>
	<true/>

	<!-- Screen recording for OCR and visual detection -->
	<key>com.apple.security.device.camera</key>
	<false/>

	<key>com.apple.security.device.microphone</key>
	<false/>

	<!-- File access for logs export -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Required for app distribution -->
	<key>com.apple.security.cs.allow-jit</key>
	<false/>

	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<false/>

	<key>com.apple.security.cs.disable-executable-page-protection</key>
	<false/>

	<!-- NO privilege escalation -->
	<key>com.apple.security.authorization.device-confinement</key>
	<true/>

	<!-- NO Apple Events to other processes -->
	<key>com.apple.security.automation.apple-events</key>
	<false/>

	<!-- NO debugger attachment -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Required for background operations -->
	<key>com.apple.security.network.client</key>
	<false/>

	<key>com.apple.security.network.server</key>
	<false/>
</dict>
</plist>
